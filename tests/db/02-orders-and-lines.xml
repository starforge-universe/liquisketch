<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="02-create-orders" author="liquisketch-fixture">
        <createTable tableName="orders">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="placed_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            constraintName="fk_orders_user"
            baseTableName="orders"
            baseColumnNames="user_id"
            referencedTableName="users"
            referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="02-create-order-lines" author="liquisketch-fixture">
        <createTable tableName="order_lines">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sku" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            constraintName="fk_order_lines_order"
            baseTableName="order_lines"
            baseColumnNames="order_id"
            referencedTableName="orders"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
